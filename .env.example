ETHEREUM_PROVIDER_URL=https://eth-mainnet.g.alchemy.com/v2/
ARBITRUM_PROVIDER_URL=https://arb-mainnet.g.alchemy.com/v2/
BASE_PROVIDER_URL=https://base-mainnet.g.alchemy.com/v2/

# FUSION_PRIVATE_KEY: wallet signing key for Keeper auth (CLI/MCP alpha-config
# access). A secret: never write it to disk or config, only set it as an env var.
# FUSION_PRIVATE_KEY=0x_your_wallet_private_key

# FUSION_KEEPER_URL: keeper endpoint; defaults to https://api.mainnet.ipor.io.
# Override for local dev:
# FUSION_KEEPER_URL=http://localhost:9066
